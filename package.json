{
  "name": "journal-ai",
  "version": "1.0.0",
  "type": "module",
  "description": "AI Journal with Semantic Search",
  "scripts": {
    "start": "node --env-file=.env --import=tsx src/server.ts",
    "dev": "node --env-file=.env --import=tsx --watch src/server.ts",
    "seed": "tsx src/seed.ts",
    "test": "tsx src/test.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "openai": "^4.24.0",
    "pg": "^8.10.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
