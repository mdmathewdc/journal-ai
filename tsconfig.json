{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "preserve",
    "target": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src"]
}
